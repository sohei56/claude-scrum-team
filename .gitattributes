# Auto-detect text files and normalize line endings
* text=auto

# Shell scripts must use LF
*.sh text eol=lf

# Markdown and config files
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary

# SVG treated as text (XML-based)
*.svg text eol=lf
