{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "ProjectState": {
      "type": "object",
      "required": ["product_goal", "current_sprint_id", "phase", "created_at", "updated_at"],
      "properties": {
        "product_goal": { "type": "string", "minLength": 1 },
        "current_sprint_id": { "type": ["string", "null"] },
        "phase": {
          "type": "string",
          "enum": [
            "new",
            "requirements_sprint",
            "backlog_created",
            "sprint_planning",
            "design",
            "implementation",
            "review",
            "sprint_review",
            "retrospective",
            "integration_sprint",
            "complete"
          ]
        },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },

    "PBI": {
      "type": "object",
      "required": ["id", "title", "description", "acceptance_criteria", "status", "priority", "design_doc_paths", "depends_on_pbi_ids", "ux_change", "created_at", "updated_at"],
      "properties": {
        "id": { "type": "string", "pattern": "^pbi-\\d+$" },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "acceptance_criteria": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Testable conditions that define when the PBI is complete. Empty array when draft, non-empty when refined"
        },
        "status": {
          "type": "string",
          "enum": ["draft", "refined", "in_progress", "review", "done"]
        },
        "priority": { "type": "integer", "minimum": 1 },
        "sprint_id": { "type": ["string", "null"] },
        "implementer_id": { "type": ["string", "null"] },
        "reviewer_id": { "type": ["string", "null"] },
        "design_doc_paths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "review_doc_path": { "type": ["string", "null"] },
        "depends_on_pbi_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "ux_change": { "type": "boolean" },
        "parent_pbi_id": { "type": ["string", "null"] },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },

    "ProductBacklog": {
      "type": "object",
      "required": ["product_goal", "items", "next_pbi_id"],
      "properties": {
        "product_goal": { "type": "string", "minLength": 1 },
        "items": {
          "type": "array",
          "items": { "$ref": "#/definitions/PBI" }
        },
        "next_pbi_id": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },

    "Developer": {
      "type": "object",
      "required": ["id", "assigned_work", "status"],
      "properties": {
        "id": { "type": "string", "pattern": "^dev-\\d+-s\\d+$" },
        "assigned_work": {
          "type": "object",
          "required": ["implement", "review"],
          "properties": {
            "implement": {
              "type": "array",
              "items": { "type": "string" },
              "description": "PBI IDs this Developer implements"
            },
            "review": {
              "type": "array",
              "items": { "type": "string" },
              "description": "PBI IDs this Developer reviews (round-robin assigned)"
            }
          },
          "additionalProperties": false
        },
        "status": {
          "type": "string",
          "enum": ["active", "idle", "failed"]
        },
        "sub_agents": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Names of specialist sub-agents actually invoked via the Task tool during this Sprint (not candidates)"
        }
      },
      "additionalProperties": false
    },

    "Sprint": {
      "type": "object",
      "required": ["id", "goal", "type", "status", "pbi_ids", "developer_count", "developers", "started_at"],
      "properties": {
        "id": { "type": "string", "pattern": "^sprint-\\d+$" },
        "goal": { "type": "string", "minLength": 1 },
        "type": {
          "type": "string",
          "enum": ["requirements", "development", "integration"]
        },
        "status": {
          "type": "string",
          "enum": ["planning", "active", "cross_review", "sprint_review", "complete"]
        },
        "pbi_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "developer_count": { "type": "integer", "minimum": 1, "maximum": 6 },
        "developers": {
          "type": "array",
          "items": { "$ref": "#/definitions/Developer" }
        },
        "started_at": { "type": "string", "format": "date-time" },
        "completed_at": { "type": ["string", "null"], "format": "date-time" }
      },
      "additionalProperties": false
    },

    "Improvement": {
      "type": "object",
      "required": ["id", "sprint_id", "description", "status", "created_at"],
      "properties": {
        "id": { "type": "string" },
        "sprint_id": { "type": "string" },
        "description": { "type": "string", "minLength": 1 },
        "status": {
          "type": "string",
          "enum": ["active", "archived"]
        },
        "created_at": { "type": "string", "format": "date-time" },
        "archived_at": { "type": ["string", "null"], "format": "date-time" }
      },
      "additionalProperties": false
    },

    "ImprovementLog": {
      "type": "object",
      "required": ["entries"],
      "properties": {
        "entries": {
          "type": "array",
          "items": { "$ref": "#/definitions/Improvement" }
        },
        "last_consolidation_sprint": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },

    "SprintSummary": {
      "type": "object",
      "required": ["id", "goal", "type", "pbis_completed", "pbis_total", "started_at", "completed_at"],
      "properties": {
        "id": { "type": "string" },
        "goal": { "type": "string" },
        "type": { "type": "string", "enum": ["requirements", "development", "integration"] },
        "pbis_completed": { "type": "integer", "minimum": 0 },
        "pbis_total": { "type": "integer", "minimum": 0 },
        "started_at": { "type": "string", "format": "date-time" },
        "completed_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },

    "SprintHistory": {
      "type": "object",
      "required": ["sprints"],
      "properties": {
        "sprints": {
          "type": "array",
          "items": { "$ref": "#/definitions/SprintSummary" }
        }
      },
      "additionalProperties": false
    },

    "CommunicationMessage": {
      "type": "object",
      "required": ["timestamp", "sender_id", "sender_role", "type", "content"],
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "sender_id": { "type": "string", "minLength": 1 },
        "sender_role": { "type": "string", "minLength": 1 },
        "recipient_id": { "type": ["string", "null"] },
        "type": {
          "type": "string",
          "enum": ["task_assignment", "progress_update", "review_request", "review_result", "phase_notification", "change_request", "file_change", "agent_spawn", "status_change", "session_event"]
        },
        "content": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },

    "CommunicationsLog": {
      "type": "object",
      "required": ["messages"],
      "properties": {
        "messages": {
          "type": "array",
          "items": { "$ref": "#/definitions/CommunicationMessage" }
        },
        "max_messages": { "type": "integer", "minimum": 1, "default": 200 }
      },
      "additionalProperties": false
    },

    "DashboardEvent": {
      "type": "object",
      "required": ["timestamp", "type", "detail"],
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "type": {
          "type": "string",
          "enum": ["task_completed", "teammate_idle", "file_changed", "phase_transition", "subagent_start", "subagent_stop"]
        },
        "agent_id": { "type": ["string", "null"] },
        "pbi_id": { "type": ["string", "null"] },
        "file_path": { "type": ["string", "null"], "description": "File path for file_changed events" },
        "change_type": {
          "type": ["string", "null"],
          "enum": ["created", "modified", "deleted", null],
          "description": "Change type for file_changed events"
        },
        "detail": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },

    "DashboardEvents": {
      "type": "object",
      "required": ["events"],
      "properties": {
        "events": {
          "type": "array",
          "items": { "$ref": "#/definitions/DashboardEvent" }
        },
        "max_events": { "type": "integer", "minimum": 1, "default": 100 }
      },
      "additionalProperties": false
    },

    "TestError": {
      "type": "object",
      "required": ["test_name", "message"],
      "properties": {
        "test_name": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },

    "TestCategory": {
      "type": "object",
      "required": ["name", "status", "total", "passed", "failed", "skipped", "errors", "runner_command", "executed_at"],
      "properties": {
        "name": {
          "type": "string",
          "enum": ["unit", "integration", "e2e", "smoke", "regression", "browser"]
        },
        "status": {
          "type": "string",
          "enum": ["pending", "running", "passed", "failed", "skipped"]
        },
        "total": { "type": "integer", "minimum": 0 },
        "passed": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "skipped": { "type": "integer", "minimum": 0 },
        "errors": {
          "type": "array",
          "items": { "$ref": "#/definitions/TestError" }
        },
        "runner_command": { "type": "string" },
        "executed_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },

    "CatalogConfig": {
      "type": "object",
      "required": ["enabled"],
      "properties": {
        "enabled": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[A-Z]+-\\d+$" },
          "description": "Spec IDs from catalog.md that are active for this project"
        }
      },
      "additionalProperties": false
    },

    "TestResults": {
      "type": "object",
      "required": ["categories", "overall_status", "started_at", "updated_at"],
      "properties": {
        "categories": {
          "type": "array",
          "items": { "$ref": "#/definitions/TestCategory" }
        },
        "overall_status": {
          "type": "string",
          "enum": ["pending", "running", "passed", "failed"]
        },
        "started_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    }
  }
}
